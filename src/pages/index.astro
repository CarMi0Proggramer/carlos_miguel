---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Introduction from "../components/Introduction.astro";
import NavbarElement from "../components/NavbarElement.astro";
import NavbarLanguage from "../components/NavbarLanguage.astro";
import USA from "../components/flags/usa.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Carlos Miguel">
    <Navbar>
        <NavbarLanguage title="English (US)" slot="language">
            <USA className="size-5 me-2" slot="svg" />
        </NavbarLanguage>
        <NavbarElement
            slot="pages"
            title="Home"
            href="/"
            className="block py-2 px-3 text-white bg-custom-redLight rounded md:text-custom-redLight md:bg-transparent md:p-0"
        />
        <NavbarElement slot="pages" title="About" href="/about" />
        <NavbarElement slot="pages" title="Projects" href="/projects" />
    </Navbar>
    <Introduction
        body="I have a deep passion for programming and a knack for solving complex challenges. From crafting engaging front-end experiences to building robust back-end systems, I love every aspect of the development process."
    />
    <Footer />

    <style>
        body {
            display: flex;
            flex-direction: column;
        }
    </style>
</Layout>
