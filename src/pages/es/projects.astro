---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import NavbarElement from "../../components/NavbarElement.astro";
import NavbarLanguages from "../../components/NavbarLanguages.astro";
import SPAIN from "../../components/flags/spain.astro";
import ProjectsContainer from "../../components/ProjectsContainer.astro";
---

<Layout es={true} title="Proyectos">
    <Navbar>
        <NavbarLanguages title="Español (ES)" slot="language">
            <SPAIN className="size-5 me-2" slot="svg" />
        </NavbarLanguages>
        <NavbarElement slot="pages" title="Inicio" href="/es/" />
        <NavbarElement slot="pages" title="Sobre mí" href="/es/about" />
        <NavbarElement
            slot="pages"
            title="Proyectos"
            href="/es/projects"
            className="block py-2 px-3 text-white bg-custom-redLight rounded md:text-custom-redLight md:bg-transparent md:p-0"
        />
        <NavbarElement slot="pages" title="Contactar" href="/es/contact" />
    </Navbar>
    <ProjectsContainer es={true} />
</Layout>
