---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import NavbarElement from "../components/NavbarElement.astro";
import NavbarLanguage from "../components/NavbarLanguage.astro";
import EN from "../components/flags/en.astro";
---

<Layout title="About">
    <Navbar>
        <NavbarLanguage title="English (US)" slot="language">
            <EN slot="svg" />
        </NavbarLanguage>
        <NavbarElement slot="pages" title="Home" href="/" />
        <NavbarElement slot="pages" title="About" href="/about" />
        <NavbarElement slot="pages" title="Projects" href="/projects" />
        <NavbarElement
            slot="pages"
            title="Contact"
            href="/contact"
            className="block py-2 px-3 text-stone-200 bg-gradient-to-r from-cyan-500 to-blue-500 rounded md:bg-gradient-to-r md:from-cyan-500 md:to-blue-500 md:bg-clip-text md:text-transparent md:p-0"
        />
    </Navbar>
</Layout>
