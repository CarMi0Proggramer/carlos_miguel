---
import Navbar from "../components/Navbar.astro";
import NavbarElement from "../components/NavbarElement.astro";
import NavbarLanguages from "../components/NavbarLanguages.astro";
import Layout from "../layouts/Layout.astro";
import USA from "../components/flags/usa.astro";
import ContactForm from "../components/Contact.astro";
---

<Layout title="Contact" footerOptional={true}>
    <Navbar>
        <NavbarLanguages title="English (US)" slot="language">
            <USA className="size-5 me-2" slot="svg" />
        </NavbarLanguages>
        <NavbarElement slot="pages" title="Home" href="/" />
        <NavbarElement slot="pages" title="About" href="/about" />
        <NavbarElement slot="pages" title="Projects" href="/projects" />
        <NavbarElement
            slot="pages"
            title="Contact"
            href="/contact"
            className="block py-2 px-3 text-white bg-custom-redLight rounded md:text-custom-redLight md:bg-transparent md:p-0"
        />
    </Navbar>
    <ContactForm />
</Layout>
