---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/navbar/Navbar.astro";
import NavbarElement from "../components/navbar/NavbarElement.astro";
import NavbarLanguages from "../components/navbar/NavbarLanguages.astro";
import USA from "../components/flags/usa.astro";
import AboutMe from "../components/AboutMe.astro";
---

<Layout title="About">
    <Navbar>
        <NavbarLanguages title="English (US)" slot="language">
            <USA className="size-5 me-2" slot="svg" />
        </NavbarLanguages>
        <NavbarElement slot="pages" title="Home" href="/" />
        <NavbarElement
            slot="pages"
            title="About"
            href="/about"
            className="block py-2 px-3 text-white bg-custom-redLight rounded md:text-custom-redLight md:bg-transparent md:p-0"
        />
        <NavbarElement slot="pages" title="Projects" href="/projects" />
        <NavbarElement slot="pages" title="Contact" href="/contact" />
    </Navbar>
    <AboutMe />
</Layout>
