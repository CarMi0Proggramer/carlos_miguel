---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import NavbarElement from "../components/NavbarElement.astro";
import NavbarLanguage from "../components/NavbarLanguage.astro";
import EN from "../components/flags/en.astro";
import AboutMe from "../components/About.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="About">
    <Navbar>
        <NavbarLanguage title="English (US)" slot="language">
            <EN slot="svg" />
        </NavbarLanguage>
        <NavbarElement slot="pages" title="Home" href="/" />
        <NavbarElement
            slot="pages"
            title="About"
            href="/about"
            className="block py-2 px-3 text-white bg-custom-redLight rounded md:text-custom-redLight md:bg-transparent md:p-0"
        />
        <NavbarElement slot="pages" title="Projects" href="/projects" />
    </Navbar>
    <AboutMe />
    <Footer />
</Layout>
