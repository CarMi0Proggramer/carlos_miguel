---
import ContactSocialMediaLink from "./ContactSocialMediaLink.astro";
import FailedMessageModal from "./FailedMessageModal.astro";
import SuccessMessageModal from "./SuccessMessageModal.astro";

interface Props {
    es?: boolean;
}

const { es } = Astro.props;
---

<main>
    <section class="body-font relative bg-gray-200 text-gray-700">
        <div class="container mx-auto px-5 py-24">
            <div class="mb-12 flex w-full flex-col text-center items-center">
                <h1
                    class="font-bold uppercase mb-4 text-2xl text-black sm:text-3xl border-b-2 border-b-custom-redLight w-fit"
                >
                    {es ? "Ponerse en" : "Get in"}<span
                        class="text-custom-redLight"
                    >
                        {es ? "contacto" : "touch"}</span
                    >
                </h1>
                <p class="mx-auto text-base leading-relaxed lg:w-2/3">
                    {
                        es
                            ? `¡No dudes en ponerte en contacto conmigo! Ya sea que estés interesado en contratarme para un proyecto, tengas preguntas sobre mis habilidades o quieras discutir posibles colaboraciones, me encantaría saber de ti.`
                            : `Feel free to reach out to me! Whether you're interested in
                            hiring me for a project, have questions about my skills, or
                            want to discuss potential collaborations, I'd love to hear
                            from you.`
                    }
                </p>
            </div>

            <div class="mx-auto md:w-2/3 lg:w-1/2">
                <!-- form -->
                <form id="contact-form" class="-m-2 flex flex-wrap">
                    <div class="w-1/2 p-2">
                        <div class="relative">
                            <input
                                type="text"
                                id="name"
                                name="name"
                                class="peer w-full rounded border border-gray-700 bg-opacity-40 py-1 px-3 text-base leading-8 text-gray-900 placeholder-transparent outline-none transition-colors duration-200 ease-in-out focus:border-custom-redLight focus:ring-2 focus:ring-custom-redLight"
                                placeholder="Name"
                                required
                            />
                            <label
                                for="name"
                                class="absolute left-3 -top-6 bg-transparent text-sm leading-7 transition-all peer-placeholder-shown:left-3 peer-placeholder-shown:top-2 peer-placeholder-shown:text-base peer-placeholder-shown:text-gray-500 peer-focus:left-3 peer-focus:-top-6 peer-focus:text-sm peer-focus:text-custom-redLight"
                                >{es ? "Nombre" : "Name"}</label
                            >
                        </div>
                    </div>
                    <div class="w-1/2 p-2">
                        <div class="relative">
                            <input
                                type="email"
                                id="email"
                                name="email"
                                class="peer w-full rounded border border-gray-700 bg-opacity-40 py-1 px-3 text-base leading-8 text-gray-900 placeholder-transparent outline-none transition-colors duration-200 ease-in-out focus:border-custom-redLight focus:ring-2 focus:ring-custom-redLight"
                                placeholder="Email"
                                required
                            />
                            <label
                                for="email"
                                class="absolute left-3 -top-6 bg-transparent text-sm leading-7 transition-all peer-placeholder-shown:left-3 peer-placeholder-shown:top-2 peer-placeholder-shown:text-base peer-placeholder-shown:text-gray-500 peer-focus:left-3 peer-focus:-top-6 peer-focus:text-sm peer-focus:text-custom-redLight"
                                >Email</label
                            >
                        </div>
                    </div>
                    <div class="mt-4 w-full p-2">
                        <div class="relative">
                            <textarea
                                id="message"
                                name="message"
                                class="peer h-32 w-full resize-none rounded border border-gray-700 bg-opacity-40 py-1 px-3 text-base leading-6 text-gray-900 placeholder-transparent outline-none transition-colors duration-200 ease-in-out focus:border-custom-redLight focus:ring-2 focus:ring-custom-redLight"
                                placeholder="Message"
                                required></textarea>
                            <label
                                for="message"
                                class="absolute left-3 -top-6 bg-transparent text-sm leading-7 transition-all peer-placeholder-shown:left-3 peer-placeholder-shown:top-2 peer-placeholder-shown:text-base peer-placeholder-shown:text-gray-500 peer-focus:left-3 peer-focus:-top-6 peer-focus:text-sm peer-focus:text-custom-redLight"
                                >{es ? "Mensaje" : "Message"}</label
                            >
                        </div>
                    </div>
                    <div class="w-full p-2">
                        <button
                            type="submit"
                            class="mx-auto flex rounded border-0 bg-custom-redLight py-2 px-8 text-lg text-white focus:ring-4 focus:outline-none focus:ring-custom-redLight/75"
                            >{es ? "Enviar" : "Send"}</button
                        >
                    </div>
                </form>
                <div class="modals-container">
                    <SuccessMessageModal es={es}></SuccessMessageModal>
                    <FailedMessageModal es={es}></FailedMessageModal>  
                </div>            
                <!-- footer -->
                <div
                    class="mt-8 w-full border-t border-gray-800 p-2 pt-8 text-center"
                >
                    <a
                        href="mailto:carlosmiguelgarcesbasulto@gmail.com"
                        class="hover:underline hover:text-custom-redLight"
                        >carlosmiguelgarcesbasulto@gmail.com</a
                    >
                    <ul class="flex justify-center items-center mt-4 gap-4">
                        <ContactSocialMediaLink
                            href="https://www.facebook.com/profile.php?id=100040653894140&mibextid=ZbWKwL"
                        >
                            <svg
                                class="size-5 hover:fill-[#3b5998]"
                                aria-hidden="true"
                                fill="currentColor"
                                viewBox="0 0 8 19"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M6.135 3H8V0H6.135a4.147 4.147 0 0 0-4.142 4.142V6H0v3h2v9.938h3V9h2.021l.592-3H5V3.591A.6.6 0 0 1 5.592 3h.543Z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </ContactSocialMediaLink>
                        <ContactSocialMediaLink
                            href="https://github.com/CarMi0Proggramer"
                        >
                            <svg
                                class="size-5 hover:fill-black"
                                aria-hidden="true"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M10 .333A9.911 9.911 0 0 0 6.866 19.65c.5.092.678-.215.678-.477 0-.237-.01-1.017-.014-1.845-2.757.6-3.338-1.169-3.338-1.169a2.627 2.627 0 0 0-1.1-1.451c-.9-.615.07-.6.07-.6a2.084 2.084 0 0 1 1.518 1.021 2.11 2.11 0 0 0 2.884.823c.044-.503.268-.973.63-1.325-2.2-.25-4.516-1.1-4.516-4.9A3.832 3.832 0 0 1 4.7 7.068a3.56 3.56 0 0 1 .095-2.623s.832-.266 2.726 1.016a9.409 9.409 0 0 1 4.962 0c1.89-1.282 2.717-1.016 2.717-1.016.366.83.402 1.768.1 2.623a3.827 3.827 0 0 1 1.02 2.659c0 3.807-2.319 4.644-4.525 4.889a2.366 2.366 0 0 1 .673 1.834c0 1.326-.012 2.394-.012 2.72 0 .263.18.572.681.475A9.911 9.911 0 0 0 10 .333Z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </ContactSocialMediaLink>
                        <ContactSocialMediaLink
                            href="https://www.linkedin.com/in/carlos-miguel-2421972ba?lipi=urn%3Ali%3Apage%3Ad_flagship3_profile_view_base_contact_details%3B%2FqLi5XXtQcOVVWpvBGxtoQ%3D%3D"
                        >
                            <svg
                                class="size-5 hover:fill-primary-600"
                                width="256"
                                height="256"
                                preserveAspectRatio="xMidYMid"
                                viewBox="0 0 256 256"
                                fill="currentColor"
                                ><path
                                    d="M218.123 218.127h-37.931v-59.403c0-14.165-.253-32.4-19.728-32.4-19.756 0-22.779 15.434-22.779 31.369v60.43h-37.93V95.967h36.413v16.694h.51a39.907 39.907 0 0 1 35.928-19.733c38.445 0 45.533 25.288 45.533 58.186l-.016 67.013ZM56.955 79.27c-12.157.002-22.014-9.852-22.016-22.009-.002-12.157 9.851-22.014 22.008-22.016 12.157-.003 22.014 9.851 22.016 22.008A22.013 22.013 0 0 1 56.955 79.27m18.966 138.858H37.95V95.967h37.97v122.16ZM237.033.018H18.89C8.58-.098.125 8.161-.001 18.471v219.053c.122 10.315 8.576 18.582 18.89 18.474h218.144c10.336.128 18.823-8.139 18.966-18.474V18.454c-.147-10.33-8.635-18.588-18.966-18.453"
                                    fill-rule="evenodd"
                                    clip-rule="evenodd"></path></svg
                            >
                        </ContactSocialMediaLink>
                    </ul>
                </div>
            </div>
        </div>
    </section>
</main>
<script>
    import { clearFormInputs } from "../utils/clear_form_inputs";

    const form = document.getElementById("contact-form") as HTMLFormElement;

    form.addEventListener("submit", (event) => {
        event.preventDefault();
        const formData = new FormData(event.target as HTMLFormElement);
        
        fetch("/api/send-email", {
            method: "POST",
            body: formData,
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                clearFormInputs(form);
                document.getElementById("open-success-modal")?.click()
            }else {
                document.getElementById("open-failed-modal")?.click()
            }
        })
        .catch(err => console.log(err));
    });
</script>
