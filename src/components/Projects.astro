const PROJECTS: Project[] = [
    {
        title: "D-Kanto | E-commerce",
        body: "This is an e-commerce website developed from scratch by me. I made it with a lot of patience and dedication using best practices and clean code rules. I developed a pagination method so the user can see the products in a more comfortable way. Here, if users are not signed in then they can't execute their payment. I also added light and dark theme.",
        image: "../../images/d-kanto-frontend.png",
        repository: "https://github.com/CarMi0Proggramer/d-kanto-frontend",
        preview: "https://d-kanto-frontend.onrender.com",
        skills: [
            {
                name: "HTML5",
                path: "../../svgs/html.svg",
            },
            {
                name: "CSS3",
                path: "../../svgs/css.svg",
            },
            {
