                path: "../../svgs/Git.svg",
            },
        ],
    },
    {
        title: "API for D-Kanto and D-Kanto Admins",
        body: "RESTful API developed following the Software Architecture pattern MVC ( Model - View - Controller ). I used TypeORM to manage the interactions with a PostgreSQL database and also handled JWTs ( JSON Web Tokens ) to allow admins and users both register and login. I handle the payment endpoints using Stripe and validate data with Zod library.",
        image: "../../images/d-kanto-backend.png",
        repository: "https://github.com/CarMi0Proggramer/d-kanto-backend",
        skills: [
            {
                name: "TypeScript",
                path: "../../svgs/typescript.svg",
            },
            {
                name: "Express.js",
                path: "../../svgs/express.svg",
            },
            {
