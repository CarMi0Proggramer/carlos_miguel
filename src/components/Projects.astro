---

<main class="m-auto">
    <section class="bg-gray-200 antialiased">
        <div
            class="max-w-screen-xl px-4 py-8 mx-auto lg:px-6 sm:py-16 lg:py-24"
        >
            <div class="max-w-2xl mx-auto text-center">
                <h2
                    class="text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl text-custom-redLight">
                    My work
                </h2>
                <p
                    class="mt-4 text-base font-normal text-gray-500 sm:text-xl"
                >
                    These are the projects I'm proud the most.
                </p>
            </div>

            <div
                class="grid grid-cols-1 mt-12 place-content-center sm:mt-16 gap-x-20 gap-y-12"
            >
                {PROJECTS.map((project) => <ProjectCard project={project} />)}
            </div>
        </div>
    </section>
</main>
