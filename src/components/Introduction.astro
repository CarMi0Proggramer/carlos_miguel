---
interface Props {
    title: string;
    body: string;
}

const { title, body } = Astro.props;
---

<main
    class="flex-1 max-w-screen-xl w-full h-full mx-auto flex flex-col md:flex-row md:justify-between md:mt-16 p-5 md:p-0 md:px-10 md:bg-[url('../../images/yo.png')] md:bg-no-repeat md:bg-contain md:bg-center"
>
    <section
        class="hidden max-w-72 md:flex md:flex-col md:gap-5 md:text-5xl lg:text-6xl flex-1 bg-gradient-to-r from-cyan-500 to-blue-500 bg-clip-text text-transparent relative"
    >
        <div class="flex flex-col">
            <p>Carlos</p>
            <p
                class="ml-5 mt-2 after:absolute after:w-10 after:h-px after:bg-stone-600 after:left-1 after:top-28 lg:after:top-[135px]"
            >
                Miguel<span class="text-stone-600">.</span>
            </p>
        </div>
        <div class="flex flex-col text-sm text-stone-500 font-bold">
            <span>Github | LinkedIn</span>
            <span>Facebook | Gmail</span>
        </div>
        <a
            href="/projects"
            class="flex text-sm self-start ml-3 border-solid border-2 p-3 rounded-lg uppercase border-stone-900 text-stone-900 cursor-pointer"
            >Contact me</a
        >
    </section>
    <section
        class="w-full md:max-w-72 text-left flex flex-col gap-4 px-5 md:px-0 flex-1 text-stone-600"
    >
        <h1
            class="mt-5 md:m-0 text-3xl md:text-4xl bg-gradient-to-r from-cyan-500 to-blue-500 bg-clip-text text-transparent"
        >
            {title}
        </h1>
        <div class="flex flex-col px-1 gap-1">
            <p class="md:text-sm lg:text-md">{body}</p>
            <a class="text-stone-600 hover:underline font-bold" href="/about">
                Read more <svg
                    class="w-4 inline-block fill-stone-600"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 -960 960 960"
                    ><path
                        d="M647-440H160v-80h487L423-744l57-56 320 320-320 320-57-56 224-224Z"
                    ></path>
                </svg>
            </a>
        </div>
    </section>
</main>

<style></style>
