---
interface Props {
    title: string;
    body: string;
}

const { title, body } = Astro.props;
---

<main
    class="max-w-screen-xl w-full h-full mx-auto flex flex-col md:flex-row md:justify-between mt-16 md:px-10"
>
    <section class="hidden max-w-72 md:block md:text-4xl lg:text-6xl">
            <p>Carlos</p>
            <p class="ml-5 mt-2">Miguel<span class="text-custom-redLight">.</span></p>
    </section>

    <section class="min-w-80">
        <img class="md:w-96 mx-auto h-full object-contain object-center" src="../../yo.png" alt="My image">
    </section>

    <section class="w-full md:max-w-72 text-left md:flex md:flex-col px-5 md:px-0">
        <h1 class="mt-5 md:m-0 text-3xl md:text-4xl">{title}</h1>
        <p class="mt-2 md:text-sm lg:text-md">{body}</p>
        <a class="mt-2" href="/about">
            Read more <svg
                class="w-4 inline-block"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 -960 960 960"
                fill="#e8eaed"
                ><path
                    d="M647-440H160v-80h487L423-744l57-56 320 320-320 320-57-56 224-224Z"
                ></path>
            </svg>
        </a>
    </section>
</main>

<style></style>
