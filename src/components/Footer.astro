---

<footer
    class="bg-white rounded-lg shadow sm:flex sm:items-center sm:justify-between p-4 sm:p-6 xl:p-8 antialiased"
>
    <p class="mb-4 text-sm text-center text-gray-600 sm:mb-0">
        &copy; 2024 <a
            href="/"
            class="hover:underline">Carlos Miguel</a
        >. All rights reserved.
    </p>
    <div class="flex justify-center items-center space-x-1">
        <a
            href="https://www.facebook.com/profile.php?id=100040653894140&mibextid=ZbWKwL"
            target="_blank"
            data-tooltip-target="tooltip-facebook"
            class="inline-flex justify-center p-2 text-gray-600 rounded-lg cursor-pointer hover:text-gray-900 hover:bg-gray-100"
        >
            <svg
                class="w-4 h-4"
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                fill="currentColor"
                viewBox="0 0 8 19"
            >
                <path
                    fill-rule="evenodd"
                    d="M6.135 3H8V0H6.135a4.147 4.147 0 0 0-4.142 4.142V6H0v3h2v9.938h3V9h2.021l.592-3H5V3.591A.6.6 0 0 1 5.592 3h.543Z"
                    clip-rule="evenodd"></path>
            </svg>
            <span class="sr-only">Facebook</span>
        </a>
        <div
            id="tooltip-facebook"
            role="tooltip"
            class="inline-block absolute invisible z-10 py-2 px-3 text-sm font-medium text-white bg-gray-900 rounded-lg shadow-sm opacity-0 transition-opacity duration-300 tooltip"
        >
            Like me on Facebook
            <div class="tooltip-arrow" data-popper-arrow></div>
        </div>
        <a
            href="https://www.linkedin.com/in/carlos-miguel-2421972ba?lipi=urn%3Ali%3Apage%3Ad_flagship3_profile_view_base_contact_details%3B%2FqLi5XXtQcOVVWpvBGxtoQ%3D%3D"
            target="_blank"
            data-tooltip-target="tooltip-twitter"
            class="inline-flex justify-center p-2 text-gray-600 rounded-lg cursor-pointer hover:text-gray-900 hover:bg-gray-100"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-brand-linkedin"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                    d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z"
                ></path><path d="M8 11l0 5"></path><path d="M8 8l0 .01"
                ></path><path d="M12 16l0 -5"></path><path
                    d="M16 16v-3a2 2 0 0 0 -4 0"></path></svg
            >
            <span class="sr-only">LinkedIn</span>
        </a>
        <div
            id="tooltip-twitter"
            role="tooltip"
            class="inline-block absolute invisible z-10 py-2 px-3 text-sm font-medium text-white bg-gray-900 rounded-lg shadow-sm opacity-0 transition-opacity duration-300 tooltip"
        >
            Follow me on LinkedIn
            <div class="tooltip-arrow" data-popper-arrow></div>
        </div>
        <a
            href="https://github.com/CarMi0Proggramer"
            target="_blank"
            data-tooltip-target="tooltip-github"
            class="inline-flex justify-center p-2 text-gray-600 rounded-lg cursor-pointer hover:text-gray-900 hover:bg-gray-100"
        >
            <svg
                class="w-4 h-4"
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                fill="currentColor"
                viewBox="0 0 20 20"
            >
                <path
                    fill-rule="evenodd"
                    d="M10 .333A9.911 9.911 0 0 0 6.866 19.65c.5.092.678-.215.678-.477 0-.237-.01-1.017-.014-1.845-2.757.6-3.338-1.169-3.338-1.169a2.627 2.627 0 0 0-1.1-1.451c-.9-.615.07-.6.07-.6a2.084 2.084 0 0 1 1.518 1.021 2.11 2.11 0 0 0 2.884.823c.044-.503.268-.973.63-1.325-2.2-.25-4.516-1.1-4.516-4.9A3.832 3.832 0 0 1 4.7 7.068a3.56 3.56 0 0 1 .095-2.623s.832-.266 2.726 1.016a9.409 9.409 0 0 1 4.962 0c1.89-1.282 2.717-1.016 2.717-1.016.366.83.402 1.768.1 2.623a3.827 3.827 0 0 1 1.02 2.659c0 3.807-2.319 4.644-4.525 4.889a2.366 2.366 0 0 1 .673 1.834c0 1.326-.012 2.394-.012 2.72 0 .263.18.572.681.475A9.911 9.911 0 0 0 10 .333Z"
                    clip-rule="evenodd"></path>
            </svg>
            <span class="sr-only">Github</span>
        </a>
        <div
            id="tooltip-github"
            role="tooltip"
            class="inline-block absolute invisible z-10 py-2 px-3 text-sm font-medium text-white bg-gray-900 rounded-lg shadow-sm opacity-0 transition-opacity duration-300 tooltip"
        >
            Star me on GitHub
            <div class="tooltip-arrow" data-popper-arrow></div>
        </div>
    </div>
</footer>
