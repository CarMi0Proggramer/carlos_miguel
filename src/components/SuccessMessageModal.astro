---
import CloseModalButton from "./CloseModalButton.astro";
import ModalIcon from "./ModalIcon.astro";

interface Props {
    es?: boolean;
}

const { es } = Astro.props;
---

<button id="open-success-modal" data-modal-toggle="successModal" class="hidden"
    >Open Modal Button</button
>
<div
    id="successModal"
    data-modal-target="successModal"
    tabindex="-1"
    aria-hidden="true"
    class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-modal md:h-full"
>
    <div class="relative p-4 w-full max-w-md h-full md:h-auto">
        <!-- Modal content -->
        <div
            class="relative p-4 text-center bg-white rounded-lg shadow dark:bg-gray-800 sm:p-5"
        >
            <CloseModalButton id="successModal" />
            <ModalIcon
                name="Success"
                className="w-12 h-12 rounded-full bg-green-100 dark:bg-green-900 p-2 flex items-center justify-center mx-auto mb-3.5"
            >
                <svg
                    aria-hidden="true"
                    class="w-8 h-8 text-green-500 dark:text-green-400"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                    xmlns="http://www.w3.org/2000/svg"
                    ><path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"></path></svg
                >
            </ModalIcon>
            <p class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">
                {
                    es
                        ? "¡Mensaje enviado con éxito! Pronto estaré en contacto contigo."
                        : "Message sent successfully! I'll get in touch with you soon."
                }
            </p>
            <button
                data-modal-toggle="successModal"
                type="button"
                class="py-2 px-3 text-sm font-medium text-center text-white rounded-lg bg-custom-redLight/90 hover:bg-custom-redLight focus:ring-4 focus:outline-none focus:ring-custom-redLight/75"
            >
                Continue
            </button>
        </div>
    </div>
</div>
