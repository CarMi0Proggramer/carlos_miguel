---
import Footer from "../components/footer/Footer.astro";

interface Props {
    title: string;
    footerOptional?: boolean;
    es?: boolean;
}

const { title, footerOptional, es } = Astro.props;
---

<!doctype html>
<html lang={es ? "es" : "en"}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/webp" href="/images/logo.webp" />
        <meta name="generator" content={Astro.generator} />
        <!-- Primary Meta Tags -->
        <meta name="title" content="Carlos Miguel" />
        <meta
            name="description"
            content="FullStack Web Developer with a deep passion for programming and a knack for solving complex challenges. From crafting engaging front-end experiences to building robust back-end systems, I love every aspect of the development process."
        />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://carlos-miguel.onrender.com/" />
        <meta property="og:title" content="Carlos Miguel" />
        <meta
            property="og:description"
            content={es
                ? "Desarrollador Web FullStack una profunda pasión por la programación y una habilidad para resolver desafíos complejos. Desde crear experiencias atractivas en el front-end hasta construir sistemas robustos en el back-end, me encanta cada aspecto del proceso de desarrollo."
                : "FullStack Web Developer with a deep passion for programming and a knack for solving complex challenges. From crafting engaging front-end experiences to building robust back-end systems, I love every aspect of the development process."}
        />
        <meta property="og:image" content="/images/metatag-img.png" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta
            property="twitter:url"
            content="https://carlos-miguel.onrender.com/"
        />
        <meta property="twitter:title" content="Carlos Miguel" />
        <meta
            property="twitter:description"
            content={es
                ? "Desarrollador Web FullStack una profunda pasión por la programación y una habilidad para resolver desafíos complejos. Desde crear experiencias atractivas en el front-end hasta construir sistemas robustos en el back-end, me encanta cada aspecto del proceso de desarrollo."
                : "FullStack Web Developer with a deep passion for programming and a knack for solving complex challenges. From crafting engaging front-end experiences to building robust back-end systems, I love every aspect of the development process."}
        />
        <meta property="twitter:image" content="/images/metatag-img.png" />
        <title>{title}</title>
    </head>
    <body>
        <slot />
        {!footerOptional && <Footer es={es} />}
    </body>
</html>
<style is:global>
    body {
        @apply flex flex-col justify-between font-body min-h-dvh overflow-x-hidden bg-gray-200;
    }
</style>
